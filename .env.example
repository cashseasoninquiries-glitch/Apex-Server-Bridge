# Apex Server Bridge — environment variables
# Copy this file to `.env` and fill in real values. Never commit the
# real `.env` file. tests/test_env_presence.py fails if this file and
# the variables actually referenced in the service code or
# docker-compose.yml ever drift apart from each other.

# ── Postgres (apex_postgres_vault) ──────────────────────────────────
POSTGRES_USER=apex_admin
POSTGRES_PASSWORD=
POSTGRES_DB=apex_vault
# POSTGRES_HOST=apex_postgres_vault

# ── Redis (apex_redis_queue) ─────────────────────────────────────────
REDIS_PASSWORD=
# REDIS_HOST=apex_redis_queue

# ── MinIO (apex_minio_lake) ──────────────────────────────────────────
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ── ClickHouse (apex_clickhouse_lake) ────────────────────────────────
CLICKHOUSE_DB=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# ── Alpaca (execution_engine, regime_detector, strategy_mvp) ────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# ALPACA_PAPER_TRADING=True
# DEFAULT_ORDER_QTY=1
# FILL_TIMEOUT_SECS=10

# ── TradingView webhook auth (ingestion_gateway) ─────────────────────
TRADINGVIEW_SECRET=

# ── Discord notifications (discord_notifier) ─────────────────────────
# DISCORD_WEBHOOK_URL=

# ── strategy_mvp (reference/example strategy) ────────────────────────
# STRATEGY_MVP_ID=strategy_mvp_sma
# STRATEGY_MVP_TICKER=AAPL
# STRATEGY_MVP_FAST_PERIOD=9
# STRATEGY_MVP_SLOW_PERIOD=21
# STRATEGY_MVP_POLL_SECONDS=300
